# Copy to .env and fill in values. Both .env and .env.local are gitignored.

DATABASE_URL=postgresql://segment:segment@localhost:5432/segment

# Embeddings (sentence-transformers)
MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_DIM=384
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
EMBED_BATCH_SIZE=32
RETRIEVAL_TOP_K=8

# LLM: auto | groq | ollama
LLM_PROVIDER=auto
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
